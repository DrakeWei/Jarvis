FEISHU_MCP_HOST=127.0.0.1
FEISHU_MCP_PORT=8765
FEISHU_MCP_BEARER_TOKEN=replace-with-local-shared-secret

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_DOC_BASE_URL=https://feishu.cn/docx

# Override these only if runtime verification proves your tenant needs a different path shape.
FEISHU_DOC_CONVERT_PATH=/open-apis/docx/v1/documents/blocks/convert
FEISHU_DOC_CREATE_NESTED_BLOCKS_PATH_TEMPLATE=/open-apis/docx/v1/documents/{document_id}/blocks/{block_id}/descendant
FEISHU_DOC_UPDATE_BLOCK_PATH_TEMPLATE=/open-apis/docx/v1/documents/{document_id}/blocks/{block_id}
FEISHU_DOC_DELETE_CHILDREN_PATH_TEMPLATE=/open-apis/docx/v1/documents/{document_id}/blocks/{block_id}/children/batch_delete

FEISHU_TOKEN_REFRESH_SKEW_SECONDS=1800
FEISHU_MAX_RETRIES=3
