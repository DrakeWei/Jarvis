    {
      "kind": "tool_used",
      "tool_name": "run_test"
    },
    {
      "kind": "tool_status_is",
      "tool_name": "run_test",
      "statuses": ["completed"]
    },
    {
      "kind": "tool_output_contains_all",
      "tool_name": "run_test",
      "contains": ["exit_code=0"]
    },
    {
      "kind": "terminal_turn_status_in",
      "statuses": ["completed"]
    },
    {
      "kind": "workspace_diff_not_empty"
    },
    {
      "kind": "max_pending_approval_count",
      "max_count": 0
    }
  ],
  "notes": "First mutating smoke task. Should exercise code reading, edit, and verification."
